    <RootNamespace>where_is_waldo_api_csharp</RootNamespace>
    <UserSecretsId>f3a7ffde-0ae7-42fc-a84b-3e0655f861bc</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.8" />
